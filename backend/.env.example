# NSE EDGE v5 — Zerodha Kite Connect Configuration
# cp .env.example .env
# Then run: python3 generate_token.py (do this every morning)

# ─── REQUIRED ──────────────────────────────────────────────────────────────────
# Get from: https://developers.kite.trade/
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# Generated daily by: python3 generate_token.py
# Expires at midnight — regenerate every morning before trading
KITE_ACCESS_TOKEN=paste_todays_token_here

# ─── AUTO REFRESH (headless login — used by startup + /api/token-refresh) ─────
# Zerodha → Profile → Security → 2FA → show secret (Base32, no spaces).
# If you rotated 2FA or token refresh fails, update KITE_TOTP_SECRET and retry.
# KITE_USER_ID=
# KITE_PASSWORD=
# KITE_TOTP_SECRET=

# Optional: set false to debug Playwright login in a visible browser window
# PLAYWRIGHT_KITE_HEADLESS=true

# ─── OPTIONAL ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── TRADING ACCOUNT (for Gate 5 position sizing) ──────────────────────────────
# Your total trading capital in ₹. Gate 5 uses 1% risk per trade by default.
# ACCOUNT_VALUE=500000
# RISK_PER_TRADE=0.01
# Only if you must force a different port than PORT (rare): NSE_EDGE_PORT=8765

# ─── TELEGRAM ALERTS (optional) ────────────────────────────────────────────────
# Create a bot via @BotFather. Chat ID: message the bot, then open:
#   https://api.telegram.org/bot<TOKEN>/getUpdates  →  message.chat.id
# For @harshvtrade: they must /start your bot first, then use their numeric chat id below.
# Test: POST http://localhost:8000/api/telegram/test
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional extra recipients (comma-separated numeric chat ids)
# TELEGRAM_CHAT_IDS=
# Dedicated slot for second user (e.g. harshvtrade’s numeric id)
# TELEGRAM_CHAT_ID_HARSHVTRADE=
# Defaults: only ADV-SPIKES (NIFTY 200) + ADV INDEX TG. Set 1 to re-enable others.
# TELEGRAM_NOTIFY_SIGNAL_ENGINE=0
# TELEGRAM_NOTIFY_INDEX_RADAR=0
# TELEGRAM_NOTIFY_ADV_SPIKES=1
# TELEGRAM_NOTIFY_ADV_INDEX=1
# Daily 9:00 IST digest (off by default; set 1 to enable)
MORNING_TELEGRAM_BRIEF=0
