# NSE EDGE v5 — Zerodha Kite Connect Configuration
# cp .env.example .env
# Then run: python3 generate_token.py (do this every morning)

# ─── REQUIRED ──────────────────────────────────────────────────────────────────
# Get from: https://developers.kite.trade/
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# Generated daily by: python3 generate_token.py
# Expires at midnight — regenerate every morning before trading
KITE_ACCESS_TOKEN=paste_todays_token_here

# ─── OPTIONAL ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8765
