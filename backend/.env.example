# â”€â”€â”€ REQUIRED â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Get from: https://developers.kite.trade/
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# Generated daily by: python3 generate_token.py or python auto_token.py
# Expires at midnight â€” regenerate every morning before trading
# If the server is already running after you update this file: POST /api/token-reload-env or UI "LOAD .ENV"
KITE_ACCESS_TOKEN=paste_todays_token_here

# Optional (local single-desk): after Nexus Login Hub connects Zerodha, allow pushing that desk
# token into the main Trading OS Kite feed (quotes / WS) without editing .env by hand.
# ALLOW_DESK_TOKEN_TO_MAIN_FEED=1
# Optional: also write KITE_ACCESS_TOKEN + KITE_API_KEY into this file when pushing from Nexus.
# DESK_SYNC_WRITE_DOTENV=1

# â”€â”€â”€ AUTO REFRESH (headless login â€” used by startup + /api/token-refresh) â”€â”€â”€â”€â”€
# Zerodha â†’ Profile â†’ Security â†’ 2FA â†’ show secret (Base32, no spaces).
# If you rotated 2FA or token refresh fails, update KITE_TOTP_SECRET and retry.
# KITE_USER_ID=
# KITE_PASSWORD=
# KITE_TOTP_SECRET=

# Optional: false = visible browser (solve CAPTCHA manually; script waits then submits).
# PLAYWRIGHT_KITE_HEADLESS=true
# Use installed Google Chrome: chrome | msedge | (omit for Playwright Chromium)
# PLAYWRIGHT_KITE_CHANNEL=chrome
# Seconds to wait in headed mode before clicking Login (CAPTCHA typing time). Default 25.
# KITE_HEADED_PRELOGIN_WAIT_SEC=25
# If Zerodha shows 2FA setup / method choice, headed mode waits up to this many seconds.
# KITE_HEADED_2FA_SETUP_WAIT_SEC=180

# â”€â”€â”€ OPTIONAL â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
HOST=0.0.0.0
PORT=8000

# Live INDEX HUNT / INDEX_RADAR: balanced_v2 | index_precision | index_elite | precision_v2 | legacy
# precision_v2 = ranked daily pick + session-open lock + ML filter when model file is present
# STRATEGY_PROFILE=precision_v2

# â”€â”€â”€ TRADING ACCOUNT (for Gate 5 position sizing) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Your total trading capital in â‚¹. Gate 5 uses 1% risk per trade by default.
# ACCOUNT_VALUE=500000
# RISK_PER_TRADE=0.01
# Only if you must force a different port than PORT (rare): NSE_EDGE_PORT=8765

# â”€â”€â”€ TELEGRAM ALERTS (optional) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Create a bot via @BotFather. Chat ID: message the bot, then open:
#   https://api.telegram.org/bot<TOKEN>/getUpdates  â†’  message.chat.id
# For @harshvtrade: they must /start your bot first, then use their numeric chat id below.
